# =========================
# mold_main 前端默认环境配置
# 说明：
# 1. 统一后端入口使用 8211
# 2. 账号接口、主业务接口、Continue 接口默认都指向同一个后端
# 3. 语音识别和 TTS 仍保留独立服务地址
# =========================

# ========== 主 API 配置 ==========
# 主后端服务地址
VITE_API_BASE_URL=http://192.168.1.152:8211
# 统一 API 前缀
VITE_API_PREFIX=/api/v1
# 账号与管理类接口地址
VITE_AUTH_BASE_URL=http://192.168.1.152:8211
# WebSocket 服务地址
VITE_WS_BASE_URL=http://192.168.1.152:8211
# Continue 相关接口地址
VITE_CONTINUE_API_BASE_URL=http://192.168.1.152:8211

# ========== 音频服务配置 ==========
# 语音识别服务地址
VITE_SPEECH_RECOGNITION_BASE_URL=http://192.168.1.152:8888
# 文本转语音服务地址
VITE_TTS_BASE_URL=http://192.168.1.154:8000

# ========== 本地开发配置 ==========
# Vite 本地开发端口
VITE_DEV_SERVER_PORT=3000
