# ============================================================
# mold_main 后端环境配置
# 说明：
# 1. 本文件用于统一后端、内嵌 worker、MCP、语音识别、TTS 等服务
# 2. 修改配置后通常需要重启对应服务才会生效
# 3. 统一后端当前默认端口为 8212
# 4. 语音识别服务默认端口为 8888，TTS 服务默认端口为 8890
# 5. CAD/价格搜索 MCP 服务默认端口为 8201
# ============================================================

# ============================================================
# 一、应用基础信息
# 用于统一后端自身的名称、版本和默认端口
# PORT 是主服务对外暴露的统一端口
# ============================================================
APP_NAME=mold_main_backend
APP_VERSION=3.0.0
PORT=8212

# ============================================================
# 二、API Gateway / 统一后端监听地址
# 这几组端口目前保持一致，都是为了兼容不同模块读取方式
# 一般只需要关心 PORT=8212 即可
# 0.0.0.0 表示允许局域网其他机器访问
# ============================================================
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8212

SERVER_HOST=0.0.0.0
SERVER_PORT=8212

API_HOST=0.0.0.0
API_PORT=8212

# ============================================================
# 三、运行模式
# DEBUG=true 允许返回更详细错误信息
# RELOAD=false 表示关闭热重载，适合当前这种包含 worker / 模型加载的重服务
# ============================================================
DEBUG=true
RELOAD=false

# ============================================================
# 四、内嵌 Worker 配置
# START_EMBEDDED_WORKER=true 时，执行 python main.py 会同时拉起 worker
# EMBEDDED_WORKER_ENTRY 当前使用 all_tasks_worker，可同时消费：
# - job_processing
# - pricing_recalculate
# ============================================================
START_EMBEDDED_WORKER=true
EMBEDDED_WORKER_ENTRY=workers/all_tasks_worker.py

# ============================================================
# 五、跨域配置
# 前端开发环境访问统一后端时需要放行的来源
# 如增加新的前端端口，需要把新的 origin 加到这里
# ============================================================
CORS_ORIGINS=http://192.168.3.61:3001,http://192.168.3.61:5173,http://192.168.3.61:5174,http://localhost:3001,http://localhost:5173,http://localhost:5174,http://127.0.0.1:3001,http://127.0.0.1:5173,http://127.0.0.1:5174

# ============================================================
# 六、PostgreSQL 数据库
# 用于存储任务、子图、特征、价格、审核状态等核心业务数据
# DB_MAX_OVERFLOW 用于连接池额外溢出连接数
# ============================================================
DB_HOST=192.168.3.61
DB_PORT=5432
DB_NAME=mold_cost_db
DB_USER=postgres
DB_PASSWORD=lzp1314..
DB_MAX_OVERFLOW=5

# ============================================================
# 七、Redis
# 用于：
# - WebSocket 进度推送
# - 审核会话状态缓存
# - 分布式锁 / review 状态存储
# ============================================================
REDIS_URL=redis://192.168.3.61:6379

# ============================================================
# 八、RabbitMQ
# 用于异步任务队列
# 主要队列：
# - job_processing：主编排任务
# - job_processing_dlx：死信队列
# ============================================================
RABBITMQ_HOST=192.168.3.61
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=123456
RABBITMQ_QUEUE_JOB_PROCESSING=job_processing
RABBITMQ_QUEUE_DLX=job_processing_dlx

# ============================================================
# 九、MinIO 对象存储
# 用于存放上传文件、拆图结果、导出报表、图纸文件等
# MINIO_EXTERNAL_ENDPOINT 通常给前端或外部访问时使用
# ============================================================
MINIO_ENDPOINT=192.168.3.61:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=12345678
MINIO_REGION=us-east-1
MINIO_USE_HTTPS=false
MINIO_BUCKET_FILES=files
MINIO_EXTERNAL_ENDPOINT=192.168.3.61:9000

# ============================================================
# 十、JWT 鉴权
# 用于账户系统登录态与访问令牌签发
# 生产环境务必替换 JWT_SECRET_KEY
# ============================================================
JWT_SECRET_KEY=your-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================================
# 十一、日志配置
# LOG_LEVEL=DEBUG 会打印较多调试日志，排查问题时更方便
# ENABLE_JSON_LOG=false 表示使用普通文本日志
# LOG_MAX_BYTES / LOG_BACKUP_COUNT 供日志轮转使用
# ============================================================
LOG_LEVEL=DEBUG
LOG_DIR=logs
ENABLE_JSON_LOG=false
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_ROTATION_TIME=00:00
LOG_RETENTION_DAYS=5
LOG_COMPRESSION=zip

# ============================================================
# 十二、上传限制
# MAX_FILE_SIZE_MB 控制单文件最大上传大小（MB）
# ALLOWED_FILE_EXTENSIONS 控制允许上传的文件后缀
# ============================================================
MAX_FILE_SIZE_MB=1000
ALLOWED_FILE_EXTENSIONS=.dwg,.prt

# ============================================================
# 十三、CAD / 价格搜索 MCP 服务
# CAD_PRICE_SEARCH_MCP_URL：统一后端调用 MCP 的地址
# CAD_PRICE_SEARCH_MCP_HOST / PORT：MCP 服务自身监听地址
# CAD_SERVER_HOST / PORT：保留给 CAD 子服务兼容读取
# ============================================================
CAD_PRICE_SEARCH_MCP_URL=http://192.168.3.61:8201
CAD_SERVER_HOST=0.0.0.0
CAD_SERVER_PORT=8202
CAD_PRICE_SEARCH_MCP_HOST=0.0.0.0
CAD_PRICE_SEARCH_MCP_PORT=8201

# ============================================================
# 十四、统一后端内部回调接口
# 这些 URL 主要给 Agent / ConfirmHandler / 业务流程内部互相调用
# 都指向当前统一后端 8212 端口
# ============================================================
FEATURE_REPROCESS_API_URL=http://127.0.0.1:8212/api/features/reprocess
PRICING_RECALCULATE_API_URL=http://127.0.0.1:8212/api/pricing/recalculate
PRICING_RECALCULATE_FALLBACK_URL=http://127.0.0.1:8212/api/pricing/recalculate
WEIGHT_PRICE_API_URL=http://127.0.0.1:8212/api/price_wg/calculate

# ============================================================
# 十五、外部业务服务
# NC_AGENT_URL：NC 时间计算服务
# NC_AGENT_TIMEOUT：NC 服务超时时间，当前是 10 秒
# SPEECH_SERVICE_URL：Whisper 语音识别服务地址
# TTS_SERVICE_URL：CosyVoice 文字转语音服务地址
# ============================================================
NC_AGENT_URL=http://192.168.3.101:8001
NC_AGENT_TIMEOUT=9600
NC_AGENT_REQUEST_TIMEOUT=180
NC_AGENT_POLL_INTERVAL=60

# NC excel文件保留的时间
NC_EXCEL_RETENTION_DAYS=7

NC_SOURCE_DB_HOST=192.168.3.67
NC_SOURCE_DB_PORT=5432
NC_SOURCE_DB_NAME=ceshi
NC_SOURCE_DB_USER=postgres
NC_SOURCE_DB_PASSWORD=root
NC_SOURCE_TABLE=nc

NC_SOURCE_MINIO_ENDPOINT=192.168.3.61:9000
NC_SOURCE_MINIO_ACCESS_KEY=admin
NC_SOURCE_MINIO_SECRET_KEY=12345678
NC_SOURCE_MINIO_REGION=us-east-1
NC_SOURCE_MINIO_USE_HTTPS=false
NC_SOURCE_MINIO_BUCKET=ncresult
SPEECH_SERVICE_URL=http://192.168.3.61:8888
TTS_SERVICE_URL=http://192.168.3.61:8890

# ============================================================
# 十六、CAD / NX / 媒体工具路径
# ODA_FILE_CONVERTER_PATH：DWG/DXF 转换工具
# NX_BIN_DIR：Siemens NX 安装目录中的 NXBIN，用于 NXOpen / journal 等功能
# FFMPEG_PATH：Whisper 处理音频格式转换必需
# ============================================================
ODA_FILE_CONVERTER_PATH=D:\ODAFileConverter 26.7.0\ODAFileConverter.exe
NX_BIN_DIR=D:\Program Files\Siemens\NX2312\NXBIN
FFMPEG_PATH=C:\Users\lzp\AppData\Local\Microsoft\WinGet\Packages\Gyan.FFmpeg.Essentials_Microsoft.Winget.Source_8wekyb3d8bbwe\ffmpeg-8.1-essentials_build\bin\ffmpeg.exe

# ============================================================
# 十七、CosyVoice TTS 配置
# COSYVOICE_ROOT：CosyVoice 根目录，当前已迁移到 backend/tts_services/CosyVoice
# TTS_MODEL_DIR：默认加载的模型目录
# TTS_DEFAULT_MODE：默认推理模式，sft 最适合当前本地模型
# TTS_HOST / TTS_PORT：独立 TTS 服务监听地址
# ============================================================
COSYVOICE_ROOT=D:\AI\Pycharm\chengben2\mold_main\backend\tts_services\CosyVoice
TTS_MODEL_DIR=D:\AI\Pycharm\chengben2\mold_main\backend\tts_services\CosyVoice\pretrained_models\CosyVoice-300M-SFT
TTS_DEFAULT_MODE=sft
TTS_HOST=0.0.0.0
TTS_PORT=8890

# ============================================================
# 十八、大模型与对话行为配置
# OPENAI_BASE_URL：当前接的是本地兼容 OpenAI 接口的大模型服务
# USE_LLM：是否启用 LLM 能力
# USE_LLM_FOR_QUERY_DETAILS：查询详情时是否调用 LLM 做润色解释
# USE_CHAT_HISTORY：是否带历史消息上下文
# MAX_HISTORY_MESSAGES：历史消息条数上限
# API_TIMEOUT：普通外部 HTTP 接口超时（秒）
# LLM_TIMEOUT：LLM 接口超时（秒）
# ============================================================
OPENAI_API_KEY=sk-dummy
OPENAI_MODEL=Qwen3-30B-A3B-Instruct
OPENAI_BASE_URL=http://192.168.3.131:8000/v1 #局域网
# OPENAI_BASE_URL=https://qwen3.qyagent.top/v  #公网

# OPENAI_API_KEY=Bearer sk-92868c203a0a4c7b8c9a2145496ea822
# OPENAI_MODEL=qwen-plus
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
USE_LLM=true
USE_LLM_FOR_QUERY_DETAILS=true
USE_CHAT_HISTORY=true
MAX_HISTORY_MESSAGES=10
LLM_TEMPERATURE=0
MAX_RETRIES=3
API_TIMEOUT=60
LLM_TIMEOUT=180

# ============================================================
# 十九、监控端口
# 如果后续接 Prometheus / Grafana，可直接使用这些端口
# ============================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# NC  json文件保留的时间
NC_LOG_RETENTION_DAYS=30
NC_LOG_CLEANUP_INTERVAL_DAYS=1

# 板料线补线输出 DXF 清理配置
PLATE_LINE_OUTPUT_RETENTION_DAYS=7
PLATE_LINE_OUTPUT_CLEANUP_INTERVAL_DAYS=1
