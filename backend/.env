# =========================
# mold_main 统一后端环境配置
# 说明：
# 1. 当前对外统一服务端口使用 8211
# 2. 前端建议统一访问同一个后端地址
# 3. 内部依赖如 Redis / RabbitMQ / MinIO / MCP 仍保留各自端口
# =========================

# ========== 基础应用配置 ==========
# 应用名称
APP_NAME=mold_main_backend
# 应用版本
APP_VERSION=3.0.0
# 对外统一端口
PORT=8211

# API Gateway 监听地址与端口
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8211

# 通用服务监听地址与端口
SERVER_HOST=0.0.0.0
SERVER_PORT=8211

# API 主服务监听地址与端口
API_HOST=0.0.0.0
API_PORT=8211

# 调试模式
DEBUG=true
# 是否开启热重载
RELOAD=true

# 允许跨域的前端地址，多个地址用逗号分隔
CORS_ORIGINS=http://192.168.1.157:3000,http://192.168.1.157:5173,http://192.168.1.157:5174,http://localhost:3000,http://localhost:5173,http://localhost:5174

# ========== 数据库配置 ==========
# PostgreSQL 主机
DB_HOST=192.168.1.54
# PostgreSQL 端口
DB_PORT=5432
# 数据库名
DB_NAME=mold_cost_db
# 数据库用户名
DB_USER=root
# 数据库密码
DB_PASSWORD=yunzai123

# ========== Redis 配置 ==========
# Redis 连接地址
REDIS_URL=redis://192.168.1.152:6379

# ========== RabbitMQ 配置 ==========
# RabbitMQ 主机
RABBITMQ_HOST=192.168.1.152
# RabbitMQ 端口
RABBITMQ_PORT=5672
# RabbitMQ 用户名
RABBITMQ_USER=admin
# RabbitMQ 密码
RABBITMQ_PASSWORD=123456
# 主任务队列名称
RABBITMQ_QUEUE_JOB_PROCESSING=job_processing
# 死信队列名称
RABBITMQ_QUEUE_DLX=job_processing_dlx

# ========== MinIO 配置 ==========
# MinIO 服务地址
MINIO_ENDPOINT=192.168.1.152:9000
# MinIO Access Key
MINIO_ACCESS_KEY=admin
# MinIO Secret Key
MINIO_SECRET_KEY=12345678
# MinIO 区域
MINIO_REGION=us-east-1
# 是否使用 HTTPS
MINIO_USE_HTTPS=false
# 默认文件桶名称
MINIO_BUCKET_FILES=files
# 前端或外部访问使用的 MinIO 地址
MINIO_EXTERNAL_ENDPOINT=192.168.1.152:9000

# ========== JWT 认证配置 ==========
# JWT 密钥
JWT_SECRET_KEY=your-secret-key-change-in-production-2024
# JWT 算法
JWT_ALGORITHM=HS256
# Token 过期时间，单位分钟
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ========== 日志配置 ==========
# 日志级别
LOG_LEVEL=DEBUG
# 日志目录
LOG_DIR=logs
# 是否开启 JSON 日志
ENABLE_JSON_LOG=false

# ========== 文件上传配置 ==========
# 最大上传文件大小，单位 MB
MAX_FILE_SIZE_MB=1000
# 允许上传的文件扩展名
ALLOWED_FILE_EXTENSIONS=.dwg,.prt

# ========== 内部服务与回调地址 ==========
# CAD 价格搜索 MCP 服务地址
CAD_PRICE_SEARCH_MCP_URL=http://192.168.1.152:8200
# 特征重处理接口地址
FEATURE_REPROCESS_API_URL=http://127.0.0.1:8211/api/features/reprocess
# 价格重算接口地址
PRICING_RECALCULATE_API_URL=http://127.0.0.1:8211/api/pricing/recalculate
# 价格重算回退地址
PRICING_RECALCULATE_FALLBACK_URL=http://127.0.0.1:8211/api/pricing/recalculate
# 重量价格计算接口地址
WEIGHT_PRICE_API_URL=http://127.0.0.1:8211/api/price_wg/calculate

# ========== 外部业务服务配置 ==========
# NC Agent 地址
NC_AGENT_URL=http://192.168.1.223:8001
# NC Agent 超时时间，单位秒
NC_AGENT_TIMEOUT=7200
# 语音服务地址
SPEECH_SERVICE_URL=http://192.168.1.152:8888

# ========== 大模型配置 ==========
# 大模型 API Key
OPENAI_API_KEY=sk-dummy
# 使用的模型名
OPENAI_MODEL=Qwen3-30B-A3B-Instruct
# 大模型服务地址
OPENAI_BASE_URL=http://192.168.0.22:8000/v1
API_TIMEOUT=60
LLM_TIMEOUT=30
