# =========================
# mold_main backend config
# main backend port: 8212
# speech service port: 8888
# CAD Price Search MCP port: 8201
# =========================

# app
APP_NAME=mold_main_backend
APP_VERSION=3.0.0
PORT=8212

# api gateway
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8212

# unified backend server
SERVER_HOST=0.0.0.0
SERVER_PORT=8212

# api
API_HOST=0.0.0.0
API_PORT=8212

DEBUG=true
RELOAD=true

# embedded worker
START_EMBEDDED_WORKER=true
EMBEDDED_WORKER_ENTRY=workers/all_tasks_worker.py

# cors
CORS_ORIGINS=http://192.168.1.152:3001,http://192.168.1.152:5173,http://192.168.1.152:5174,http://localhost:3001,http://localhost:5173,http://localhost:5174,http://127.0.0.1:3001,http://127.0.0.1:5173,http://127.0.0.1:5174

# database
DB_HOST=192.168.1.54
DB_PORT=5432
DB_NAME=mold_cost_db
DB_USER=root
DB_PASSWORD=yunzai123
DB_MAX_OVERFLOW=5

# redis
REDIS_URL=redis://192.168.1.152:6379

# rabbitmq
RABBITMQ_HOST=192.168.1.152
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=123456
RABBITMQ_QUEUE_JOB_PROCESSING=job_processing
RABBITMQ_QUEUE_DLX=job_processing_dlx

# minio
MINIO_ENDPOINT=192.168.1.152:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=12345678
MINIO_REGION=us-east-1
MINIO_USE_HTTPS=false
MINIO_BUCKET_FILES=files
MINIO_EXTERNAL_ENDPOINT=192.168.1.152:9000

# jwt
JWT_SECRET_KEY=your-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# logging
LOG_LEVEL=DEBUG
LOG_DIR=logs
ENABLE_JSON_LOG=false
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# upload
MAX_FILE_SIZE_MB=1000
ALLOWED_FILE_EXTENSIONS=.dwg,.prt

# mcp
CAD_PRICE_SEARCH_MCP_URL=http://192.168.1.152:8201
CAD_SERVER_HOST=0.0.0.0
CAD_SERVER_PORT=8202
CAD_PRICE_SEARCH_MCP_HOST=0.0.0.0
CAD_PRICE_SEARCH_MCP_PORT=8201

# callbacks
FEATURE_REPROCESS_API_URL=http://127.0.0.1:8212/api/features/reprocess
PRICING_RECALCULATE_API_URL=http://127.0.0.1:8212/api/pricing/recalculate
PRICING_RECALCULATE_FALLBACK_URL=http://127.0.0.1:8212/api/pricing/recalculate
WEIGHT_PRICE_API_URL=http://127.0.0.1:8212/api/price_wg/calculate

# external services
NC_AGENT_URL=http://192.168.1.223:8001
NC_AGENT_TIMEOUT=7200
SPEECH_SERVICE_URL=http://192.168.1.152:8888

# cad and nx tools
ODA_FILE_CONVERTER_PATH=D:\AI\ODA\ODAFileConverter.exe
NX_BIN_DIR=D:\Program Files\Siemens\NX2312\NXBIN

# llm
OPENAI_API_KEY=sk-dummy
OPENAI_MODEL=Qwen3-30B-A3B-Instruct
OPENAI_BASE_URL=http://192.168.0.22:8000/v1
USE_LLM=true
USE_LLM_FOR_QUERY_DETAILS=true
USE_CHAT_HISTORY=true
MAX_HISTORY_MESSAGES=10
LLM_TEMPERATURE=0
MAX_RETRIES=3
API_TIMEOUT=60
LLM_TIMEOUT=30

# monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
